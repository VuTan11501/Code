{
  "name": "fjp-workflow-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Static frontend for FJP Workflow Dashboard (gh-pages).",
  "scripts": {
    "build:css": "tailwindcss -i src/tailwind-input.css -o docs/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i src/tailwind-input.css -o docs/css/tailwind.css --watch",
    "build:js": "node scripts/build-js.mjs --obfuscate",
    "build:js:fast": "node scripts/build-js.mjs",
    "build": "npm run build:css && npm run build:js",
    "test:smoke": "playwright test",
    "test:smoke:install": "playwright install --with-deps chromium",
    "test:unit": "vitest run",
    "test": "vitest run",
    "generate:codegraph": "madge --json src > docs/codegraph/deps.json",
    "generate:codegraph:graph": "madge --image docs/codegraph/deps.png src"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "esbuild": "^0.28.0",
    "javascript-obfuscator": "^5.4.3",
    "tailwindcss": "^3.4.13",
    "vitest": "^4.1.7",
    "madge": "^5.0.0"
  }
}
